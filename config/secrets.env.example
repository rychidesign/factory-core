# Rychi Design Factory secrets — server-side runtime config.
#
# Real file lives at: /home/factory/.config/factory/secrets.env (chmod 600).
# Source of truth for everything systemd units inject via EnvironmentFile.
#
# server-setup.sh seeds this template into place on first run; subsequent
# runs leave the populated file untouched. Edit the live file directly,
# never commit a populated copy back to factory-core.

# ─── Opencode ──────────────────────────────────────────────────────────
# Subscription token for opencode go ($10/mo). Required for any agent run.
OPENCODE_TOKEN=

# ─── LLM providers ─────────────────────────────────────────────────────
# Used by figma-designer (Gemini 3.1 Pro) and as fallback when opencode
# rate-limits per ADR-0001 reevaluation triggers.
GEMINI_API_KEY=

# Optional fallback / specialty calls.
ANTHROPIC_API_KEY=

# ─── Figma MCP ─────────────────────────────────────────────────────────
# Figma personal access token for the figma-designer + figma-extractor
# agents. Generate at: https://www.figma.com/settings → Personal access
# tokens. Required scopes: file_read, file_write, file_dev_resources_write.
FIGMA_PERSONAL_ACCESS_TOKEN=

# ─── Cloudflare ────────────────────────────────────────────────────────
# Used by deployer agent to push to Cloudflare Pages.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Sanity (per-project values, but common ones live here) ────────────
# Per-project Sanity project IDs live in clients/<id>/.factory-state/
# workspace/.env. The token below is the *manage* token used to bootstrap
# new Sanity projects from the cms-builder agent.
SANITY_MANAGEMENT_TOKEN=

# ─── Vercel (alternate deploy target) ──────────────────────────────────
VERCEL_TOKEN=

# ─── Telegram (Wave 5: monitor + escalation) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── GitHub (per-project repo creation) ────────────────────────────────
# Personal access token with repo + delete_repo scopes. Used by
# bootstrap-agent to create a private repo per client project.
GITHUB_TOKEN=
GITHUB_ORG=rychidesign

# ─── Factory runtime overrides (rarely changed) ────────────────────────
# Uncomment to override defaults set by systemd unit files.
# FACTORY_AUDIT_LOG=/home/factory/factory-logs/permission-audit.jsonl
# FACTORY_TOOL_EVENT_LOG=/home/factory/factory-logs/tool-events.jsonl

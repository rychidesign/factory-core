{
  "name": "factory-template-astro-sanity",
  "version": "0.1.0",
  "description": "Starter for Rychi Design Factory client projects on the astro-sanity track. Astro 5 + Tailwind 4 + Sanity hosted CMS + shadcn/ui via React islands.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev --force",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint . && astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.3.0",
    "@sanity/client": "^7.10.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.50.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.0"
  }
}
